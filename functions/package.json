{
  "name": "functions",
  "description": "Cloud Functions for Platform Backend",
  "scripts": {
    "lint": "eslint .",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "lint:fix": "eslint --ext .js ./ --fix",
    "format": "prettier --write .",
    "generate-docs": "jsdoc -c jsdoc.json",
    "prepare": "npm run generate-docs",
    "serve-docs": "http-server docs",
    "docs": "npm run generate-docs && npm run serve-docs",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage",
    "test:emulator": "firebase emulators:exec --only functions 'npm test'",
    "emulators": "firebase emulators:start --only functions,firestore,database --inspect-functions",
    "genkit": "npx genkit start -- npm run emulators"
  },
  "engines": {
    "node": "20"
  },
  "main": "index.js",
  "dependencies": {
    "@genkit-ai/core": "^1.0.4",
    "@genkit-ai/dotprompt": "^0.9.12",
    "@genkit-ai/firebase": "^1.0.4",
    "@genkit-ai/google-cloud": "^1.0.4",
    "@genkit-ai/googleai": "^1.0.4",
    "@genkit-ai/vertexai": "^1.0.4",
    "@octokit/rest": "^19.0.13",
    "axios": "^1.4.0",
    "busboy": "^1.6.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.17.1",
    "firebase-admin": "^13.1.0",
    "firebase-functions": "^6.3.1",
    "genkit": "^1.0.4",
    "moment": "^2.29.4",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.24.5",
    "@jest/globals": "^29.7.0",
    "@stylistic/eslint-plugin-js": "^1.8.0",
    "@types/jest": "^29.5.12",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "firebase-functions-test": "^3.1.0",
    "genkit-cli": "^1.0.4",
    "http-server": "^14.1.1",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.3",
    "prettier": "^3.2.5"
  },
  "private": true,
  "version": "1.0.0",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
